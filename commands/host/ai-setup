#!/bin/bash

#ddev-generated
## Description: Interactive setup wizard for DDEV AI development tools
## Usage: ai-setup
## Example: "ddev ai-setup"
## ExecRaw: true

echo "=== DDEV AI Workspace Setup ==="
echo ""

# --- Claude Code ---
echo "--- Claude Code Configuration ---"
echo ""

ENV_CLAUDE=".ddev/.env.claude-code"

if [ -f "$ENV_CLAUDE" ]; then
    echo "Found: $ENV_CLAUDE"
    if grep -q "ANTHROPIC_API_KEY" "$ENV_CLAUDE" 2>/dev/null; then
        current_key=$(grep "ANTHROPIC_API_KEY" "$ENV_CLAUDE" | head -1 | cut -d= -f2-)
        if [ -n "$current_key" ] && [ "$current_key" != "your-api-key-here" ]; then
            echo "  ANTHROPIC_API_KEY is set."
        else
            echo "  ANTHROPIC_API_KEY is not configured."
        fi
    fi
else
    echo "Not found: $ENV_CLAUDE (will be created by ddev-claude-code add-on on restart)"
fi

echo ""
echo "Authentication options:"
echo "  1) OAuth login (recommended) — run: ddev claude-code claude login"
echo "  2) API key — set ANTHROPIC_API_KEY in $ENV_CLAUDE"
echo ""
read -rp "Choose [1/2/skip]: " claude_choice

case "$claude_choice" in
    1)
        echo ""
        echo "Run this command after setup completes and DDEV restarts:"
        echo "  ddev claude-code claude login"
        echo ""
        ;;
    2)
        echo ""
        read -rp "Enter your Anthropic API key (sk-ant-...): " api_key
        if [ -n "$api_key" ]; then
            if [ -f "$ENV_CLAUDE" ]; then
                if grep -q "^ANTHROPIC_API_KEY=" "$ENV_CLAUDE"; then
                    sed -i "s|^ANTHROPIC_API_KEY=.*|ANTHROPIC_API_KEY=${api_key}|" "$ENV_CLAUDE"
                elif grep -q "^#.*ANTHROPIC_API_KEY=" "$ENV_CLAUDE"; then
                    sed -i "s|^#.*ANTHROPIC_API_KEY=.*|ANTHROPIC_API_KEY=${api_key}|" "$ENV_CLAUDE"
                else
                    echo "ANTHROPIC_API_KEY=${api_key}" >> "$ENV_CLAUDE"
                fi
            else
                echo "Warning: $ENV_CLAUDE does not exist yet."
                echo "Run 'ddev restart' first to create it, then run 'ddev ai-setup' again."
            fi
            echo "API key saved to $ENV_CLAUDE"
        else
            echo "Skipped — no key entered."
        fi
        echo ""
        ;;
    *)
        echo "Skipped Claude Code configuration."
        echo ""
        ;;
esac

# --- OpenCode ---
echo "--- OpenCode Configuration ---"
echo ""

ENV_OPENCODE=".ddev/.env.opencode"

if [ -f "$ENV_OPENCODE" ]; then
    echo "Found: $ENV_OPENCODE"
    auth_dir=$(grep "HOST_OPENCODE_AUTH_DIR" "$ENV_OPENCODE" 2>/dev/null | head -1 | cut -d= -f2-)
    config_dir=$(grep "HOST_OPENCODE_CONFIG_DIR" "$ENV_OPENCODE" 2>/dev/null | head -1 | cut -d= -f2-)
    echo "  AUTH_DIR: ${auth_dir:-not set}"
    echo "  CONFIG_DIR: ${config_dir:-not set}"
else
    echo "Not found: $ENV_OPENCODE (will be created by ddev-opencode add-on on restart)"
fi

echo ""
echo "OpenCode uses an auth.json file for API credentials."
echo "The agents-sync add-on handles agent configuration automatically."
echo ""
read -rp "Do you want to configure OpenCode auth? [y/N]: " opencode_choice

if [ "$opencode_choice" = "y" ] || [ "$opencode_choice" = "Y" ]; then
    echo ""
    echo "OpenCode needs an auth.json file with your API credentials."
    echo ""

    if [ -f "$ENV_OPENCODE" ]; then
        current_auth_dir=$(grep "HOST_OPENCODE_AUTH_DIR" "$ENV_OPENCODE" 2>/dev/null | head -1 | cut -d= -f2-)
    fi
    default_auth_dir="${current_auth_dir:-${HOME}/.local/share/opencode}"

    read -rp "Auth directory [$default_auth_dir]: " auth_input
    auth_dir="${auth_input:-$default_auth_dir}"

    mkdir -p "$auth_dir"

    if [ ! -f "${auth_dir}/auth.json" ]; then
        echo ""
        echo "Provider options:"
        echo "  1) Anthropic API key"
        echo "  2) LiteLLM proxy"
        echo "  3) Skip — I'll configure it manually"
        echo ""
        read -rp "Choose [1/2/3]: " provider_choice

        case "$provider_choice" in
            1)
                read -rp "Enter your Anthropic API key (sk-ant-...): " oc_api_key
                if [ -n "$oc_api_key" ]; then
                    cat > "${auth_dir}/auth.json" << AUTHEOF
{
  "anthropic": {
    "type": "api",
    "key": "${oc_api_key}"
  }
}
AUTHEOF
                    echo "Created ${auth_dir}/auth.json"
                fi
                ;;
            2)
                read -rp "Enter your LiteLLM API key: " litellm_key
                if [ -n "$litellm_key" ]; then
                    cat > "${auth_dir}/auth.json" << AUTHEOF
{
  "litellm": {
    "type": "api",
    "key": "${litellm_key}"
  }
}
AUTHEOF
                    echo "Created ${auth_dir}/auth.json"
                fi
                ;;
            *)
                echo "Skipped. Create ${auth_dir}/auth.json manually."
                echo "See share/auth.json.example for the format."
                ;;
        esac
    else
        echo "Auth file already exists: ${auth_dir}/auth.json"
    fi

    if [ -f "$ENV_OPENCODE" ]; then
        sed -i "s|^HOST_OPENCODE_AUTH_DIR=.*|HOST_OPENCODE_AUTH_DIR=${auth_dir}|" "$ENV_OPENCODE"
        echo "Updated HOST_OPENCODE_AUTH_DIR in $ENV_OPENCODE"
    fi
    echo ""
else
    echo "Skipped OpenCode configuration."
    echo ""
fi

# --- Summary ---
echo "=== Setup Complete ==="
echo ""
echo "Next steps:"
echo "  1. Run: ddev restart"
echo "  2. Run: ddev opencode   or   ddev claude-code"
echo ""
echo "Other commands:"
echo "  ddev ralph --backend opencode   Autonomous task execution"
echo "  ddev bd list                    View tracked tasks"
echo ""
echo "Optional: Desktop notifications (install once on host):"
echo "  curl -fsSL https://raw.githubusercontent.com/trebormc/ai-notify-bridge/main/install.sh | bash"
echo ""
